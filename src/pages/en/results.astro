---
import Layout from "../../components/Layout.astro";
import ResultsApp from "../../components/ResultsApp";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const calendlyUrl = "https://calendly.com/josediegorobles";
---

<Layout
  locale="en"
  canonicalPath="/en/results/"
  title="AI Act diagnosis result | Jose Robles"
  description="Orientative AI Act classification result and applicable obligations with downloadable PDF."
>
  <ResultsApp client:load locale="en" questionnairePath={`${base}en/questionnaire/`} calendlyUrl={calendlyUrl} />
</Layout>
