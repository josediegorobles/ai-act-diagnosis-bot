---
import Layout from "../../../components/Layout.astro";
import QuestionnaireApp from "../../../components/QuestionnaireApp";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<Layout
  locale="en"
  canonicalPath="/en/questionnaire/"
  title="AI Act Questionnaire | Jose Robles"
  description="Adaptive questionnaire to classify AI systems and get orientative AI Act obligations."
>
  <QuestionnaireApp client:load locale="en" resultPath={`${base}en/results/`} />
</Layout>
